{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://odmrctl.io/schemas/run_manifest.schema.json",
  "title": "RunManifest",
  "description": "Top-level manifest for a single experiment run. Stored as runs/{run_id}/manifest.json.",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "run_id",
    "created_at_unix_ms",
    "artifact_paths"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version of the manifest format"
    },
    "kind": {
      "type": "string",
      "enum": ["run_manifest"],
      "description": "Discriminator for manifest documents"
    },
    "run_id": {
      "type": "string",
      "description": "Unique run identifier"
    },
    "created_at_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Wall-clock timestamp in milliseconds since Unix epoch"
    },
    "artifact_paths": {
      "type": "object",
      "required": [
        "manifest",
        "station_snapshot",
        "recipe_lock",
        "resolved_recipe_lock",
        "dry_run_plan_lock",
        "safety_report_lock",
        "events",
        "index",
        "raw_bin"
      ],
      "properties": {
        "manifest": { "type": "string" },
        "station_snapshot": { "type": "string" },
        "recipe_lock": { "type": "string" },
        "resolved_recipe_lock": { "type": "string" },
        "dry_run_plan_lock": { "type": "string" },
        "safety_report_lock": { "type": "string" },
        "events": { "type": "string" },
        "index": { "type": "string" },
        "raw_bin": { "type": "string" }
      }
    },
    "recipe_hash": {
      "type": "string",
      "description": "SHA-256 hash of the source recipe"
    },
    "resolved_recipe_id": {
      "type": "string",
      "description": "Identifier of the resolved recipe used for this run"
    },
    "safety_report_id": {
      "type": "string",
      "description": "Identifier of the safety report for this run"
    }
  }
}
