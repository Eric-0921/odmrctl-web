{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://odmrctl.io/schemas/station.schema.json",
  "title": "Station",
  "description": "Experimental station configuration: device inventory, connections, safety profile reference, and calibration snapshot. See examples/station.mock.json.",
  "type": "object",
  "required": ["schema_version", "kind", "id", "devices", "safety_profile_id"],
  "properties": {
    "schema_version": { "type": "string", "description": "Schema version, e.g. 0.2.0" },
    "kind": { "const": "station", "description": "Discriminator: must be 'station'" },
    "id": { "type": "string", "description": "Unique station identifier" },
    "name": { "type": "string" },
    "created_by": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "description": { "type": "string" },
    "devices": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/StationDevice" }
    },
    "safety_profile_id": { "type": "string", "description": "Reference to a SafetyLimit document" },
    "calibration_snapshot_id": { "type": "string" }
  },
  "definitions": {
    "StationDevice": {
      "type": "object",
      "required": ["device_id", "device_type", "transport", "required"],
      "properties": {
        "device_id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
        "device_type": { "type": "string", "enum": ["smb100a", "oe1022d", "laser", "magnet_xyz"] },
        "transport": { "$ref": "#/definitions/TransportConfig" },
        "profile_id": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "TransportConfig": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["tcp_scpi", "serial", "serial_group"] }
      },
      "oneOf": [
        {
          "properties": {
            "kind": { "const": "tcp_scpi" },
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          },
          "required": ["host", "port"]
        },
        {
          "properties": {
            "kind": { "const": "serial" },
            "port": { "type": "string" },
            "baud_rate": { "type": "integer" }
          },
          "required": ["port"]
        },
        {
          "properties": {
            "kind": { "const": "serial_group" },
            "ports": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["ports"]
        }
      ]
    }
  }
}
