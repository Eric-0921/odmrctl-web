{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://odmrctl.io/schemas/safety_report.schema.json",
  "title": "SafetyReport",
  "description": "Static safety interlock report for a resolved recipe. Generated by odmr-safety.",
  "type": "object",
  "required": ["schema_version", "kind", "id", "resolved_recipe_id", "decision", "summary", "findings"],
  "properties": {
    "schema_version": { "type": "string", "description": "Schema version, e.g. 0.2.0" },
    "kind": { "const": "safety_report", "description": "Discriminator: must be 'safety_report'" },
    "id": { "type": "string", "description": "Unique safety report identifier" },
    "resolved_recipe_id": { "type": "string", "description": "Reference to the ResolvedRecipe that was checked" },
    "decision": {
      "type": "string",
      "enum": ["allow", "allow_with_warnings", "reject"],
      "description": "Overall safety decision"
    },
    "summary": { "$ref": "#/definitions/SafetySummary" },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/SafetyFinding" }
    }
  },
  "definitions": {
    "SafetySummary": {
      "type": "object",
      "required": ["checked_steps", "checked_actions", "info_count", "warning_count", "error_count"],
      "properties": {
        "checked_steps": { "type": "integer", "minimum": 0 },
        "checked_actions": { "type": "integer", "minimum": 0 },
        "info_count": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 },
        "error_count": { "type": "integer", "minimum": 0 }
      }
    },
    "SafetyFinding": {
      "type": "object",
      "required": ["check_kind", "severity", "step_id", "device_id", "action", "field", "value", "limit", "message"],
      "properties": {
        "check_kind": {
          "type": "string",
          "enum": ["rf_frequency", "rf_power", "fm_deviation", "magnetic_field", "unknown_action", "missing_limit"]
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "step_id": { "type": "string" },
        "device_id": { "type": "string" },
        "action": { "type": "string" },
        "field": { "type": "string" },
        "value": { "type": "number" },
        "limit": { "type": "number" },
        "message": { "type": "string" }
      }
    }
  }
}
