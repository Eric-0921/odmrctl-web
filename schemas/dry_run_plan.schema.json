{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://odmrctl.io/schemas/dry_run_plan.schema.json",
  "title": "DryRunPlan",
  "description": "Human-readable preview of a resolved recipe. Generated by odmr-compiler. See examples/resolved/basic_odmr_mock.dry_run_plan.json.",
  "type": "object",
  "required": ["schema_version", "kind", "id", "resolved_recipe_id", "summary", "steps"],
  "properties": {
    "schema_version": { "type": "string", "description": "Schema version, e.g. 0.2.0" },
    "kind": { "const": "dry_run_plan", "description": "Discriminator: must be 'dry_run_plan'" },
    "id": { "type": "string", "description": "Unique dry-run plan identifier" },
    "resolved_recipe_id": { "type": "string", "description": "Reference to the ResolvedRecipe this plan previews" },
    "summary": { "$ref": "#/definitions/DryRunSummary" },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/definitions/DryRunStep" }
    }
  },
  "definitions": {
    "DryRunSummary": {
      "type": "object",
      "required": ["step_count", "estimated_duration_s", "required_devices", "hazard_actions"],
      "properties": {
        "step_count": { "type": "integer", "minimum": 0 },
        "estimated_duration_s": { "type": "number", "minimum": 0 },
        "required_devices": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of device_ids required by the plan"
        },
        "hazard_actions": { "type": "integer", "minimum": 0, "description": "Number of actions flagged as hazardous" }
      }
    },
    "DryRunStep": {
      "type": "object",
      "required": ["step_id", "sweep_coordinate", "device_actions", "estimated_duration_ms"],
      "properties": {
        "step_id": { "type": "string" },
        "sweep_coordinate": { "type": "object", "description": "JSON object mapping sweep axis to value for this step" },
        "device_actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Human-readable action descriptions, e.g. 'smb100a_01: set_rf_frequency'"
        },
        "estimated_duration_ms": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
