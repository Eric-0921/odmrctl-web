  "safe_scpi_sequence_to_reproduce_figure3": [
    {
      "step": 1,
      "command": "OUTP OFF",
      "long_form": "OUTPut:STATe OFF",
      "purpose": "保持 RF 微波输出关闭，避免设置过程中输出微波。",
      "expected_display": "RF OFF"
    },
    {
      "step": 2,
      "command": "MOD:STAT OFF",
      "long_form": "SOURce:MODulation:ALL:STATe OFF",
