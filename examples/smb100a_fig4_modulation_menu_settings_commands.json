  "front_panel_steps_to_reproduce_figure4_view": [
    {
      "step": 1,
      "operation": "保持或设置顶部主参数：Freq = 2.882 GHz，Level = -15.00 dBm，RF OFF，MOD OFF，ALC-Auto。",
      "scpi_equivalent": [
        "FREQ 2.882GHz",
        "POW -15dBm",
        "OUTP OFF",
        "MOD:STAT OFF",
        "POW:ALC AUTO"
      ]
    },
    {
      "step": 2,
      "operation": "使 Mod Gen 块保持 On，图中左侧显示 LF。",
      "scpi_equivalent": "LFO ON",
      "note": "若只想打开菜单而不输出LF参考，可根据实验需要设为 LFO OFF；但图4可见复选框是On。"
    },
    {
      "step": 3,
      "operation": "在主界面选择 Modulation 功能块。",
      "scpi_equivalent": null,
      "note": "选择/高亮界面元素是GUI操作，不改变远程可查询的仪器状态。"
    },
    {
      "step": 4,
      "operation": "点击 Modulation 块中的 config...，或在 Modulation 下按 [MENU] 打开调制菜单。",
      "scpi_equivalent": null,
      "manual_basis": "说明书说明调制设置可通过 block diagram 的 Modulation function block 或同名菜单进入。"
    },
    {
      "step": 5,
      "operation": "将光标移动到 Frequency Modulation...；按 Enter/旋钮确认即可进入下一张图的 Frequency Modulation 对话框。",
      "scpi_equivalent": null,
      "manual_basis": "说明书写明 To access the Frequency Modulation dialog, select Modulation > Configure > Frequency Modulation or use the [MENU] key under Modulation。",
      "important_note": "仅高亮/打开 Frequency Modulation 对话框不会自动等于 FM:STAT ON，也不会自动把顶部 MOD OFF 改成 MOD ON。"
    }
  ],
