  "front_panel_steps_to_reproduce_figure6_view": [
    {
      "step": 1,
      "operation": "保持或设置顶部主参数：Freq = 2.882 GHz，Level = -15.00 dBm，RF OFF，MOD OFF，ALC-Auto。",
      "scpi_equivalent": [
        "OUTP OFF",
        "MOD:STAT OFF",
        "FREQ:MODE CW",
        "FREQ 2.882GHz",
        "POW -15dBm",
        "POW:ALC AUTO"
      ]
    },
    {
      "step": 2,
      "operation": "从主界面进入 Modulation > config... > Frequency Modulation...。",
      "scpi_equivalent": null,
      "note": "打开前面板对话框是GUI导航动作，没有SCPI等效命令；远程控制时直接发送FM子系统命令。"
    },
    {
      "step": 3,
      "operation": "在 Frequency Modulation 对话框中设置 State = On。",
      "scpi_equivalent": "FM:STAT ON"
    },
    {
      "step": 4,
      "operation": "设置 FM Source = Int。",
      "scpi_equivalent": "FM:SOUR INT"
    },
    {
      "step": 5,
      "operation": "设置 FM Mode = High Deviation。",
      "scpi_equivalent": "FM:MODE HDEV"
    },
    {
      "step": 6,
      "operation": "设置 FM Deviation = 4.0000 MHz。",
      "scpi_equivalent": "FM:DEV 4MHz"
    },
    {
      "step": 7,
      "operation": "在 FM Source = Internal 区域设置 LFGen Freq = 500.00 Hz，LFGen Shape = Square。",
      "scpi_equivalent": [
        "LFO:FREQ 500Hz",
        "LFO:SHAP SQU"
      ]
    }
  ],
  "safe_scpi_sequence_to_reproduce_figure6": [
    {
      "step": 1,
      "command": "OUTP OFF",
      "long_form": "OUTPut:STATe OFF",
      "purpose": "关闭RF输出，匹配顶部RF OFF，并避免配置时误输出微波。",
      "expected_display": "RF OFF"
    },
    {
      "step": 2,
      "command": "MOD:STAT OFF",
      "long_form": "SOURce:MODulation:ALL:STATe OFF",
      "purpose": "关闭模拟调制总开关，匹配顶部MOD OFF。注意这不等同于关闭FM单项。",
      "expected_display": "MOD OFF"
    },
    {
      "step": 3,
      "command": "FREQ:MODE CW",
      "long_form": "SOURce:FREQuency:MODE CW",
