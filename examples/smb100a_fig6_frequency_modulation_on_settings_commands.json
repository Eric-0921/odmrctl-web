    {
      "step": 4,
      "command": "FREQ 2.882GHz",
      "long_form": "SOURce:FREQuency:CW 2.882GHz",
      "purpose": "设置顶部RF频率。",
      "expected_display": "2.882 000 000 000 GHz"
    },
    {
      "step": 5,
      "command": "POW -15dBm",
      "long_form": "SOURce:POWer:LEVel:IMMediate:AMPLitude -15dBm",
      "purpose": "设置顶部RF Level。",
      "expected_display": "-15.00 dBm"
    },
    {
      "step": 6,
      "command": "POW:ALC AUTO",
      "long_form": "SOURce:POWer:ALC:STATe AUTO",
